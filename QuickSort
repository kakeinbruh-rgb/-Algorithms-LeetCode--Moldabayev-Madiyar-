import random

# Функция partition по схеме Lomuto
def partition(arr, low, high):
    # Опорный элемент — последний элемент
    pivot = arr[high]

    # Индекс элемента, который меньше pivot
    i = low - 1

    # Проходим по массиву
    for j in range(low, high):

        # Если элемент меньше или равен pivot
        if arr[j] <= pivot:
            i += 1

            # Меняем элементы местами
            arr[i], arr[j] = arr[j], arr[i]

    # Ставим pivot на правильную позицию
    arr[i + 1], arr[high] = arr[high], arr[i + 1]

    # Возвращаем индекс pivot
    return i + 1


# QuickSort с рандомным выбором pivot
def quick_sort(arr, low, high):

    if low < high:

        # Случайный выбор опорного элемента
        random_index = random.randint(low, high)

        # Меняем его с последним элементом
        arr[random_index], arr[high] = arr[high], arr[random_index]

        # Разделяем массив
        pivot_index = partition(arr, low, high)

        # Рекурсивно сортируем левую часть
        quick_sort(arr, low, pivot_index - 1)

        # Рекурсивно сортируем правую часть
        quick_sort(arr, pivot_index + 1, high)


# Пример работы
arr = [7, 2, 9, 4, 1, 5]

quick_sort(arr, 0, len(arr) - 1)

print("Отсортированный массив:", arr)
